{
  "name": "arena-tracker",
  "private": true,
  "version": "2.0.5",
  "main": "electron.js",
  "description": "Arena Tracker - League of Legends Arena win tracker",
  "author": "Bruno Sousa",
  "scripts": {
    "setup": "npm install",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && .\\node_modules\\electron\\dist\\electron.exe electron.js\"",
    "build": "vite build",
    "clean": "rimraf dist out",
    "prebuild": "npm run clean",
    "dist": "npm run build && electron-builder",
    "electron": ".\\node_modules\\electron\\dist\\electron.exe electron.js",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "release": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "dotenv": "^17.4.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.39.0",
    "idb": "^8.0.3",
    "lucide-react": "^1.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "electron-run": "^2.4.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.2",
    "vite": "^8.0.12",
    "vite-plugin-svgr": "^5.2.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.arena.tracker",
    "productName": "Arena Tracker",
    "asar": true,
    "files": [
      "dist/**",
      "electron.js",
      "electron/**",
      "preload.js",
      "node_modules/**"
    ],
    "icon": "public/logo.ico",
    "releaseInfo": {
      "releaseNotesFile": "build/release-notes.md"
    },
    "win": {
      "target": "nsis",
      "icon": "public/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "BrunoSousa1997",
        "repo": "Arena-Tracker",
        "releaseType": "release"
      }
    ]
  }
}
